{
    "name": "@developershouse/abdere",
    "version": "1.0.0",
    "description": "The website API",
    "repository": "https://gitlab.com/developers-house/dev/website-group/abdera.git",
    "author": "Matthieu <matthieu974fr.pignolet@gmail.com>",
    "license": "MIT",
    "private": true,
    "dependencies": {
        "@aws-sdk/client-s3": "^3.13.0",
        "@developers-house/scarlet": "^2.0.0",
        "@openapitools/openapi-generator-cli": "^2.2.3",
        "@ory/hydra-client": "^1.10.5",
        "@sentry/node": "^5.28.0",
        "axios": "^0.30.0",
        "connect": "^3.7.0",
        "fastify": "^3.7.0",
        "fastify-auth": "^1.0.1",
        "fastify-cors": "^6.0.1",
        "fastify-jaeger": "^1.0.2",
        "fastify-jwt": "^3.0.1",
        "ioredis": "^4.19.2",
        "ioredis-mock": "^5.4.1",
        "jaeger-client": "^3.18.1",
        "jsonwebtoken": "^8.5.1",
        "jwks-rsa": "^2.0.4",
        "middie": "^5.2.0",
        "opentracing": "^0.14.5",
        "typescript": "^4.2.4",
        "unleash-client": "^3.8.1",
        "yaml": "^1.10.2"
    },
    "scripts": {
        "gen:client": "openapi-generator-cli generate -i openapi.yaml -g typescript-axios -o gen",
        "gen:types": "openapi-generator-cli generate -i openapi.yaml -g typescript -o src/types --global-property models",
        "build": "yarn gen:types && tsc -p .",
        "start": "node dist",
        "test": "jest",
        "test:ci": "jest --reporters=jest-junit --ci",
        "dev": "tsc -p . && yarn start",
        "format": "prettier --write src/**/*.ts{,x}",
        "lint": "tsc --noEmit && eslint src/**/*.ts{,x} --fix"
    },
    "devDependencies": {
        "@types/ioredis": "^4.17.7",
        "@types/jaeger-client": "^3.18.2",
        "@types/jest": "^26.0.22",
        "@types/node": "^14.14.41",
        "@typescript-eslint/eslint-plugin": "^4.22.0",
        "@typescript-eslint/parser": "^4.22.0",
        "eslint": "^7.27.0",
        "eslint-config-prettier": "^8.2.0",
        "eslint-plugin-array-func": "^3.1.7",
        "eslint-plugin-jsdoc": "^32.3.0",
        "eslint-plugin-json": "^2.1.2",
        "eslint-plugin-no-use-extend-native": "^0.5.0",
        "eslint-plugin-node": "^11.1.0",
        "eslint-plugin-only-error": "^1.0.2",
        "eslint-plugin-optimize-regex": "^1.2.0",
        "eslint-plugin-prettier": "^3.4.0",
        "eslint-plugin-promise": "^5.1.0",
        "eslint-plugin-regexp": "^0.8.0",
        "eslint-plugin-security": "^1.4.0",
        "eslint-plugin-sonarjs": "^0.6.0",
        "eslint-plugin-unicorn": "^29.0.0",
        "eslint-plugin-woke": "^1.0.0",
        "jest": "^26.6.3",
        "jest-junit": "^12.0.0",
        "prettier": "^2.2.1",
        "ts-jest": "^26.5.4"
    }
}