n/Bureau/Dossier Dev/Developers House/Website/website-frontend/src/hooks/useMembers.ts",[],"/home/kylian/Bureau/Dossier Dev/Developers House/Website/website-frontend/src/pages/Members/MemberDisplay.tsx",[],"/home/kylian/Bureau/Dossier Dev/Developers House/Website/website-frontend/src/components/ui/index.ts",[],"/home/kylian/Bureau/Dossier Dev/Developers House/Website/website-frontend/src/components/ui/Text/Text.tsx",[],"/home/kylian/Bureau/Dossier Dev/Developers House/Website/website-frontend/src/components/ui/Banner/Banner.tsx",[],"/home/kylian/Bureau/Dossier Dev/Developers House/Website/website-frontend/src/components/ui/Presentation/Presentation.tsx",[],"/home/kylian/Bureau/Dossier Dev/Developers House/Website/website-frontend/src/pages/Settings/sections/LinkedAccounts.tsx",["274"],"import React, { FC, ReactElement } from \"react\";\nimport { FaDiscord, FaGithub } from \"react-icons/fa\";\nimport { RiGitlabFill } from \"react-icons/ri\";\nimport { BsQuestionCircleFill } from \"react-icons/bs\";\nimport { Link } from \"@developers-house/abdera\";\nimport useLinkedAccounts from \"../../../hooks/useLinkedAccounts\";\nimport { TitleBox } from \"../../../components/ui/TitleBox/TitleBox\";\nimport { Loader } from \"../../../components/SuspenseLoader/SuspenseLoader\";\nimport { Card } from \"../../../components/ui/Card/Card\";\nimport styles from \"../settings.module.scss\";\nimport ButtonGroup from \"../../../components/ui/Button/ButtonGroup\";\nimport { Button } from \"../../../components/ui/Button/Button\";\n\nconst DisplayPlatformSVG: FC<{ platform: string }> = ({ platform }) => {\n  switch (platform) {\n    case \"discord\":\n      return <FaDiscord />;\n\n    case \"github\":\n      return <FaGithub />;\n\n    case \"gitlab\":\n      return <RiGitlabFill />;\n\n    default:\n      return <BsQuestionCircleFill />;\n  }\n};\n\nconst platforms = {\n  discord: \"Discord\",\n  github: \"GitHub\",\n  gitlab: \"GitLab\",\n};\nconst getPlatformName = (platform: keyof typeof platforms): string => {\n  if (!platforms[platform]) {\n    return platform;\n  }\n\n  return platforms[platform];\n};\n\nconst LinkedAccounts: FC = () => {\n  const { isLoading, error, data } = useLinkedAccounts();\n\n  if (error) {\n    return (\n      <TitleBox>\n        <p>\n          {error.name}: {error.message} <br /> {error.stack}\n        </p>\n      </TitleBox>\n    );\n  }\n  if (!data || isLoading) {\n    return (\n      <TitleBox>\n        <Loader />\n      </TitleBox>\n    );\n  }\n\n  return (\n    <div className={styles.links}>\n      {data.map(\n        (link: Link): ReactElement => {\n          return (\n            <Card key={link.platformId} className={styles.link}>\n              <div className={styles.title}>\n                <DisplayPlatformSVG platform={link.platform} />\n                <span>\n                  {getPlatformName(link.platform as keyof typeof platforms)}\n                </span>\n              </div>\n              <Button>Remove link</Button>\n            </Card>\n          );\n        }\n      )}\n    </div>\n  );\n};\n\nexport default LinkedAccounts;\n","/home/kylian/Bureau/Dossier Dev/Developers House/Website/website-frontend/src/hooks/useLinkedAccounts.ts",[],{"ruleId":"275","replacedBy":"276"},{"ruleId":"277","replacedBy":"278"},{"ruleId":"279","replacedBy":"280"},{"ruleId":"281","replacedBy":"282"},{"ruleId":"283","replacedBy":"284"},{"ruleId":"285","replacedBy":"286"},{"ruleId":"287","severity":1,"message":"288","line":11,"column":8,"nodeType":"289","messageId":"290","endLine":11,"endColumn":19},"jest/no-try-expect",["291"],"lines-around-directive",["292"],"global-require",[],"no-buffer-constructor",[],"no-new-require",[],"no-path-concat",[],"@typescript-eslint/no-unused-vars","'ButtonGroup' is defined but never used.","Identifier","unusedVar","no-conditional-expect","padding-line-between-statements"]