{
   "name": "amelia",
   "description": "Amelia is the API which allows to interact with the frontend of IMR & to manage data and users.",
   "author": "Kylian Prévot",
   "contributors": [
      "Matthieu Pignolet"
   ],
   "license": "MIT",
   "version": "1.1.0",
   "devDependencies": {
      "@types/jest": "^26.0.22",
      "@types/module-alias": "^2.0.1",
      "@types/node": "^8.0.29",
      "@types/node-fetch": "^2.5.10",
      "@typescript-eslint/eslint-plugin": "^4.20.0",
      "@typescript-eslint/parser": "^4.20.0",
      "dotenv": "^9.0.0",
      "eslint": "^7.23.0",
      "eslint-config-prettier": "^8.1.0",
      "eslint-plugin-array-func": "^3.1.7",
      "eslint-plugin-jsdoc": "^32.3.0",
      "eslint-plugin-json": "^2.1.2",
      "eslint-plugin-no-use-extend-native": "^0.5.0",
      "eslint-plugin-node": "^11.1.0",
      "eslint-plugin-only-error": "^1.0.2",
      "eslint-plugin-optimize-regex": "^1.2.0",
      "eslint-plugin-prettier": "^3.3.1",
      "eslint-plugin-promise": "^4.3.1",
      "eslint-plugin-regexp": "^0.7.5",
      "eslint-plugin-security": "^1.4.0",
      "eslint-plugin-sonarjs": "^0.6.0",
      "eslint-plugin-unicorn": "^29.0.0",
      "eslint-plugin-woke": "^1.0.0",
      "husky": "^6.0.0",
      "jest": "^26.6.3",
      "jest-junit": "^12.0.0",
      "prettier": "^2.2.1",
      "ts-jest": "^26.5.4",
      "ts-node": "3.3.0",
      "typescript": "^4.2.3"
   },
   "scripts": {
      "dev": "tsc -p . && node dist/src/index",
      "start": "node dist/src/index",
      "build": "yarn gen:client-axios && tsc -p .",
      "test": "jest --passWithNoTests",
      "prepare": "husky install",
      "gen:client": "openapi-generator-cli generate -i openapi.yaml -g typescript-fetch -o openapi-gen",
      "gen:client-axios": "openapi-generator-cli generate -i openapi.yaml -g typescript-axios -o openapi-gen",
      "typeorm": "node --require ts-node/register ./node_modules/typeorm/cli.js"
   },
   "dependencies": {
      "@aws-sdk/client-s3": "^3.11.0",
      "@aws-sdk/s3-request-presigner": "^3.11.0",
      "@openapitools/openapi-generator-cli": "^2.3.6",
      "@sentry/node": "^6.4.0",
      "@sentry/tracing": "^6.4.0",
      "fastify": "^3.14.1",
      "fastify-cors": "^5.2.0",
      "module-alias": "^2.2.2",
      "node-fetch": "^2.6.1",
      "pg": "^8.5.1",
      "reflect-metadata": "^0.1.10",
      "typeorm": "0.2.32"
   }
}
