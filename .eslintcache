ages":"226","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"128"},{"filePath":"227","messages":"228","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"128"},{"filePath":"229","messages":"230","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"128"},{"filePath":"231","messages":"232","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"128"},{"filePath":"233","messages":"234","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"235","messages":"236","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"237","messages":"238","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"239","messages":"240","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"128"},{"filePath":"241","messages":"242","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"243","messages":"244","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"245","messages":"246","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"247","messages":"248","errorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"249","messages":"250","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"251","messages":"252","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"128"},"/home/matthieu/WebstormProjects/website/src/index.tsx",[],["253","254","255","256","257","258"],"/home/matthieu/WebstormProjects/website/src/utilities/i18n.ts",[],"/home/matthieu/WebstormProjects/website/src/Root.tsx",[],"/home/matthieu/WebstormProjects/website/src/components/SuspenseLoader/SuspenseLoader.tsx",[],"/home/matthieu/WebstormProjects/website/src/utilities/logger.ts",[],"/home/matthieu/WebstormProjects/website/src/components/ThemeProvider/ThemeProvider.tsx",[],"/home/matthieu/WebstormProjects/website/src/components/notifications/NotificationsArea.tsx",[],"/home/matthieu/WebstormProjects/website/src/state/slices/account/hooks.ts",["259"],"/home/matthieu/WebstormProjects/website/src/pages/Navigator.tsx",[],"/home/matthieu/WebstormProjects/website/src/utilities/index.ts",[],"/home/matthieu/WebstormProjects/website/src/components/navbar/index.ts",[],"/home/matthieu/WebstormProjects/website/src/state/index.ts",[],"/home/matthieu/WebstormProjects/website/src/pages/ErrorPage.tsx",[],"/home/matthieu/WebstormProjects/website/src/state/hooks.ts",["260"],"// Use throughout your app instead of plain `useDispatch` and `useSelector`\nimport { TypedUseSelectorHook, useDispatch, useSelector } from \"react-redux\";\nimport { AppDispatch, RootState } from \"./redux\";\n\nexport const useAppDispatch = () => useDispatch<AppDispatch>();\nexport const useAppSelector: TypedUseSelectorHook<RootState> = useSelector;\n","/home/matthieu/WebstormProjects/website/src/components/notifications/NotificationComponent.tsx",[],"/home/matthieu/WebstormProjects/website/src/pages/About/About.tsx",[],"/home/matthieu/WebstormProjects/website/src/pages/NotFound/NotFound.tsx",[],"/home/matthieu/WebstormProjects/website/src/pages/Settings/Callback.tsx",[],"/home/matthieu/WebstormProjects/website/src/pages/Settings/Settings.tsx",["261"],"import React, { ReactElement, useCallback, FC, useMemo } from \"react\";\nimport { Route, Switch } from \"react-router\";\nimport { NavLink } from \"react-router-dom\";\nimport { useDispatch, useSelector } from \"react-redux\";\nimport { AiFillLock } from \"react-icons/all\";\nimport { Button, ButtonImage } from \"../../components/ui/Button/Button\";\nimport ButtonGroup from \"../../components/ui/Button/ButtonGroup\";\nimport Authorizations from \"./sections/Authorizations\";\nimport Account from \"./sections/Account\";\nimport Support from \"./sections/Support\";\nimport styles from \"./settings.module.scss\";\nimport NotFound from \"../NotFound/NotFound\";\nimport UserAvatarStatus from \"../../components/ui/UserAvatarStatus/UserAvatarStatus\";\nimport { withNetwork } from \"../../hooks/hoc/withNetwork\";\nimport DataSettings from \"./sections/DataSettings\";\nimport { useUser } from \"../../state/slices/account/hooks\";\nimport { login } from \"../../state/slices/account/actions\";\n\nconst Content: FC = () => {\n  const dispatch = useDispatch();\n  const match = useMemo(\n    () => ({\n      path: \"/settings\",\n    }),\n    []\n  );\n\n  const logout = useCallback(() => {\n    dispatch(login());\n  }, [dispatch]);\n\n  return (\n    <ButtonGroup className={styles.list} full>\n      <NavLink to={`${match.path}`}>\n        <Button>Account</Button>\n      </NavLink>\n      <NavLink to={`${match.path}/authorizations`}>\n        <Button>Manage authorizations</Button>\n      </NavLink>\n      <NavLink to={`${match.path}/linked-accounts`}>\n        <Button>Linked accounts</Button>\n      </NavLink>\n      <NavLink to={`${match.path}/privacy-settings`}>\n        <Button>Privacy settings</Button>\n      </NavLink>\n      <NavLink to={`${match.path}/support`}>\n        <Button>Support</Button>\n      </NavLink>\n      <Button onClick={logout}>\n        <ButtonImage>\n          <AiFillLock />\n        </ButtonImage>\n        Logout\n      </Button>\n    </ButtonGroup>\n  );\n};\n\nconst Settings = (): ReactElement => {\n  const match = useMemo(() => \"/settings\", []);\n  const user = useUser();\n\n  return (\n    <div className={styles.main}>\n      <div className={styles.navigation}>\n        <div className={styles.navigationHeader}>\n          <UserAvatarStatus\n            width=\"7rem\"\n            statusColor=\"grey\"\n            avatar={`https://s3.developershouse.xyz/${user?.avatar}`}\n            animate\n          />\n          <h3>{user?.username}</h3>\n        </div>\n        <Content />\n      </div>\n      <div className={styles.content}>\n        <Switch>\n          <Route exact path={`${match}`} component={Account} />\n          <Route\n            exact\n            path={`${match}/authorizations`}\n            component={Authorizations}\n          />\n          <Route\n            exact\n            path={`${match}/privacy-settings`}\n            component={DataSettings}\n          />\n          <Route exact path={`${match}/support`} component={Support} />\n          <Route path=\"*\" exact>\n            <NotFound />\n          </Route>\n        </Switch>\n      </div>\n    </div>\n  );\n};\n\nexport default withNetwork(Settings);\n","/home/matthieu/WebstormProjects/website/src/pages/Members/Members.tsx",[],"/home/matthieu/WebstormProjects/website/src/pages/Projects/Projects.tsx",[],"/home/matthieu/WebstormProjects/website/src/pages/Home/Home.tsx",[],"/home/matthieu/WebstormProjects/website/src/pages/ProjectDetails/ProjectDetails.tsx",[],"/home/matthieu/WebstormProjects/website/src/utilities/functions.ts",[],"/home/matthieu/WebstormProjects/website/src/utilities/serviceWorker.ts",[],"/home/matthieu/WebstormProjects/website/src/state/redux.ts",[],"/home/matthieu/WebstormProjects/website/src/components/navbar/Menu.tsx",[],"/home/matthieu/WebstormProjects/website/src/components/FlexContainer/FlexContainer.tsx",[],"/home/matthieu/WebstormProjects/website/src/components/ui/Button/ButtonGroup.tsx",[],"/home/matthieu/WebstormProjects/website/src/components/ui/Card/Card.tsx",[],"/home/matthieu/WebstormProjects/website/src/components/ui/Button/Button.tsx",[],"/home/matthieu/WebstormProjects/website/src/constants.ts",[],"/home/matthieu/WebstormProjects/website/src/components/CenteredMessage/CenteredMessage.tsx",[],"/home/matthieu/WebstormProjects/website/src/hooks/hoc/withNetwork.tsx",[],"/home