{
  "type": "postgres",
  "host": "<host>",
  "port": 5432,
  "username": "<username>",
  "password": "<password>",
  "database": "<database>",
  "synchronize": true,
  "logging": false,
  "entities": [
     "dist/src/entity/**/*.js"
  ],
  "migrations": [
     "dist/src/migration/**/*.js"
  ],
  "subscribers": [
     "dist/src/subscriber/**/*.js"
  ],
  "cli": {
     "entitiesDir": "src/entity",
     "migrationsDir": "src/migration",
     "subscribersDir": "src/subscriber"
  }
}